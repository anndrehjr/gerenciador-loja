generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MASTER
}

enum SalonStatus {
  ACTIVE
  SUSPENDED
}

enum ContractStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

// Um salão/barbearia/clínica assinante da plataforma. Todo dado operacional
// (clientes, serviços, profissionais, agendamentos) pertence a exatamente um
// Salon — é o limite de isolamento entre clientes da plataforma.
model Salon {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  domain    String?     @unique
  status    SalonStatus @default(ACTIVE)
  plan      String      @default("starter")

  // Identidade visual do site público e da tela de login desse salão.
  template     String  @default("minimal-studio")
  logoUrl      String?
  primaryColor String?

  // Dados cadastrais/comerciais do cliente da plataforma (uso do Painel
  // Master — nunca exposto nas rotas públicas nem no self-service do salão).
  document        String?
  legalName       String?
  ownerName       String?
  ownerPhone      String?
  ownerWhatsapp   String?
  ownerEmail      String?
  address         String?
  contractStatus  ContractStatus @default(TRIAL)
  contractDueDate DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  services      Service[]
  professionals Professional[]
  workingHours  WorkingHour[]
  timeOff       TimeOff[]
  appointments  Appointment[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // null só para usuários MASTER (equipe da plataforma, sem salão fixo)
  salon   Salon?  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String?

  @@index([salonId])
}

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@unique([salonId, email])
  @@unique([salonId, phone])
}

model Service {
  id              String        @id @default(cuid())
  name            String
  description     String?
  priceCents      Int
  durationMinutes Int           @default(30)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@unique([salonId, name])
}

model Professional {
  id           String        @id @default(cuid())
  name         String
  photoUrl     String?
  specialty    String?
  bio          String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workingHours WorkingHour[]
  timeOff      TimeOff[]
  appointments Appointment[]

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([salonId])
}

// Uma janela de trabalho por dia da semana (0=domingo..6=sábado). Um mesmo
// dia pode ter mais de uma janela (turno dividido, ex.: manhã e tarde).
// Sem nenhuma janela num dia = profissional não atende naquele dia.
model WorkingHour {
  id             String   @id @default(cuid())
  weekday        Int
  startMinute    Int
  endMinute      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([professionalId, weekday])
  @@index([salonId])
}

// Período de férias/folga de um profissional (datas, inclusive nos dois
// extremos). Sobrepõe o WorkingHour normal — o dia fica indisponível.
model TimeOff {
  id             String   @id @default(cuid())
  startDate      DateTime
  endDate        DateTime
  reason         String?
  createdAt      DateTime @default(now())

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([professionalId])
  @@index([salonId])
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  CONCLUIDO
  CANCELADO
}

model Appointment {
  id             String            @id @default(cuid())
  date           DateTime
  status         AppointmentStatus @default(AGENDADO)
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  client    Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  clientId  String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  serviceId String

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  professionalId String?

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([clientId])
  @@index([serviceId])
  @@index([date])
  @@index([professionalId])
  @@index([salonId])
}
