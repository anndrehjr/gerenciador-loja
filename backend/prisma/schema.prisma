generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MASTER
}

enum SalonStatus {
  ACTIVE
  SUSPENDED
}

enum ContractStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

// Segmento de negócio do salão — define qual identidade visual de landing
// page (template exclusivo) ele recebe nos planos PRO/PREMIUM.
enum SalonCategory {
  FEMININO
  BARBEARIA
  UNISSEX
  ESTETICA
  OUTROS
}

// Um salão/barbearia/clínica assinante da plataforma. Todo dado operacional
// (clientes, serviços, profissionais, agendamentos) pertence a exatamente um
// Salon — é o limite de isolamento entre clientes da plataforma.
model Salon {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  domain    String?     @unique
  status    SalonStatus   @default(ACTIVE)
  plan      String        @default("START")
  category  SalonCategory @default(OUTROS)

  // Identidade visual do site público e da tela de login desse salão.
  // Nos planos START, "template" ainda decide o visual (os 4 modelos
  // antigos); em PRO/PREMIUM, "category" passa a mandar na landing.
  template     String  @default("minimal-studio")
  logoUrl      String?
  bannerUrl    String?
  primaryColor String?

  // Dados cadastrais/comerciais do cliente da plataforma (uso do Painel
  // Master — nunca exposto nas rotas públicas nem no self-service do salão).
  document        String?
  legalName       String?
  tradeName       String?
  ownerName       String?
  ownerPhone      String?
  ownerWhatsapp   String?
  ownerEmail      String?
  city            String?
  state           String?
  zipCode         String?

  // Overrides livres de personalização (plano PREMIUM) — copy do hero, ordem
  // de seções, textos de cada bloco etc. Formato aberto de propósito: cada
  // bloco da landing lê só as chaves que conhece (ver frontend/src/lib/blocks).
  customization Json?
  address         String?
  contractStatus  ContractStatus @default(TRIAL)
  contractDueDate DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  clients              Client[]
  services             Service[]
  professionals        Professional[]
  workingHours         WorkingHour[]
  timeOff              TimeOff[]
  appointments         Appointment[]
  serviceProfessionals ServiceProfessional[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // null só para usuários MASTER (equipe da plataforma, sem salão fixo)
  salon   Salon?  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String?

  @@index([salonId])
}

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@unique([salonId, email])
  @@unique([salonId, phone])
}

model Service {
  id              String        @id @default(cuid())
  name            String
  description     String?
  priceCents      Int
  durationMinutes Int           @default(30)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]

  // Sem nenhum vínculo aqui = qualquer profissional do salão pode realizar
  // o serviço (comportamento de sempre). Só passa a restringir quando o
  // dono do salão vincula profissionais específicos.
  professionals ServiceProfessional[]

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@unique([salonId, name])
}

model ServiceProfessional {
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId      String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@id([serviceId, professionalId])
  @@index([professionalId])
  @@index([salonId])
}

model Professional {
  id           String        @id @default(cuid())
  name         String
  photoUrl     String?
  specialty    String?
  bio          String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workingHours WorkingHour[]
  timeOff      TimeOff[]
  appointments Appointment[]
  services     ServiceProfessional[]

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([salonId])
}

// Uma janela de trabalho por dia da semana (0=domingo..6=sábado). Um mesmo
// dia pode ter mais de uma janela (turno dividido, ex.: manhã e tarde).
// Sem nenhuma janela num dia = profissional não atende naquele dia.
model WorkingHour {
  id             String   @id @default(cuid())
  weekday        Int
  startMinute    Int
  endMinute      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([professionalId, weekday])
  @@index([salonId])
}

// Período de férias/folga de um profissional (datas, inclusive nos dois
// extremos). Sobrepõe o WorkingHour normal — o dia fica indisponível.
model TimeOff {
  id             String   @id @default(cuid())
  startDate      DateTime
  endDate        DateTime
  reason         String?
  createdAt      DateTime @default(now())

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([professionalId])
  @@index([salonId])
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  CONCLUIDO
  CANCELADO
}

model Appointment {
  id             String            @id @default(cuid())
  date           DateTime
  status         AppointmentStatus @default(AGENDADO)
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  client    Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  clientId  String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  serviceId String

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  professionalId String?

  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  salonId String

  @@index([clientId])
  @@index([serviceId])
  @@index([date])
  @@index([professionalId])
  @@index([salonId])
}
