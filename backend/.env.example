DATABASE_URL="postgresql://user:password@localhost:5432/gerenciador_loja?schema=public"
JWT_SECRET="replace-with-a-long-random-value"
PORT=4000
NODE_ENV=development
COOKIE_NAME=salao_session
# Obrigatório true quando NODE_ENV=production (cookie de sessão só trafega por HTTPS).
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# WhatsApp Cloud API (oficial, Meta) — opcional.
# Deixe as duas linhas abaixo comentadas/vazias para manter as notificações desligadas.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v20.0
# WHATSAPP_LANGUAGE=pt_BR
# WHATSAPP_TEMPLATE_CONFIRMATION=agendamento_confirmacao
# WHATSAPP_TEMPLATE_REMINDER=agendamento_lembrete
# WHATSAPP_TEMPLATE_CANCELLATION=agendamento_cancelamento
# WHATSAPP_REMINDER_HOURS_BEFORE=24
# WHATSAPP_DEFAULT_COUNTRY_CODE=55
