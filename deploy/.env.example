# Copiar para ~/gerenciador-loja/.env no VPS. Nunca versionar o .env real.
POSTGRES_USER=gerenciador_loja
POSTGRES_PASSWORD=troque-por-um-valor-gerado
POSTGRES_DB=gerenciador_loja

JWT_SECRET=troque-por-um-valor-aleatorio-longo
COOKIE_SECURE=true
CORS_ORIGIN=https://salao.andre-aguiar-jr.com.br
NODE_ENV=production

SEED_ADMIN_EMAIL=admin@salao.local
SEED_ADMIN_PASSWORD=troque-por-uma-senha-forte

# WhatsApp Cloud API (oficial, Meta) — opcional, deixe vazio para manter desligado.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_LANGUAGE=pt_BR
WHATSAPP_TEMPLATE_CONFIRMATION=agendamento_confirmacao
WHATSAPP_TEMPLATE_REMINDER=agendamento_lembrete
WHATSAPP_TEMPLATE_CANCELLATION=agendamento_cancelamento
WHATSAPP_REMINDER_HOURS_BEFORE=24
WHATSAPP_DEFAULT_COUNTRY_CODE=55
